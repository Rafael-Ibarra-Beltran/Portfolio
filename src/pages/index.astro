---
import Portfolio from '../components/Portfolio';
import { siteData } from '../data/site';
import '../styles/global.css';

const title = 'Rafael Ibarra | Software Engineer';
const description = 'Portfolio de Rafael Ibarra, Software Engineer enfocado en Backend, Cloud, DevOps y AI Integrations.';
const baseUrl = import.meta.env.BASE_URL;
const assetBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href={`${assetBase}favicon.ico`} sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href={`${assetBase}favicon-32x32.png`} />
		<link rel="icon" type="image/png" sizes="16x16" href={`${assetBase}favicon-16x16.png`} />
		<link rel="apple-touch-icon" href={`${assetBase}apple-touch-icon.png`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={`${assetBase}images/logo.png`} />
		<meta name="twitter:card" content="summary_large_image" />
		<title>{title}</title>
	</head>
	<body>
		<Portfolio data={siteData} baseUrl={baseUrl} client:load />
	</body>
</html>
